// RUN: ptoas --pto-arch=a5 --emit-pto-ir --mlir-print-ir-before-all %s 2>&1 | FileCheck %s
//
// The current PTOViewToMemref pipeline still rejects low-precision memref
// element types, so this test matches the verifier-accepted IR dump before that
// later pass runs.

module {
  func.func @tcvt_low_precision_a5_valid() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %src0 = pto.declare_tile -> !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst0 = pto.declare_tile -> !pto.tile_buf<loc=vec, dtype=f8E4M3FN, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %src1 = pto.declare_tile -> !pto.tile_buf<loc=vec, dtype=bf16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst1 = pto.declare_tile -> !pto.tile_buf<loc=vec, dtype=!pto.f4E1M2x2, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %src2 = pto.declare_tile -> !pto.tile_buf<loc=vec, dtype=!pto.hif8, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst2 = pto.declare_tile -> !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tcvt ins(%src0 : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
             outs(%dst0 : !pto.tile_buf<loc=vec, dtype=f8E4M3FN, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tcvt ins(%src1 : !pto.tile_buf<loc=vec, dtype=bf16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
             outs(%dst1 : !pto.tile_buf<loc=vec, dtype=!pto.f4E1M2x2, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tcvt ins(%src2 : !pto.tile_buf<loc=vec, dtype=!pto.hif8, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
             outs(%dst2 : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}

// CHECK: func.func @tcvt_low_precision_a5_valid() attributes {pto.kernel_kind = #pto.kernel_kind<vector>}
// CHECK: pto.tcvt ins(%0 {rmode = #pto<round_mode CAST_RINT>, satmode = #pto<saturation_mode OFF>} : !pto.tile_buf<vec, 16x16xf32>) outs(%1 : !pto.tile_buf<vec, 16x16xf8E4M3FN>)
// CHECK: pto.tcvt ins(%2 {rmode = #pto<round_mode CAST_RINT>, satmode = #pto<saturation_mode OFF>} : !pto.tile_buf<vec, 16x16xbf16>) outs(%3 : !pto.tile_buf<vec, 16x16x!pto.f4E1M2x2>)
// CHECK: pto.tcvt ins(%4 {rmode = #pto<round_mode CAST_RINT>, satmode = #pto<saturation_mode OFF>} : !pto.tile_buf<vec, 16x16x!pto.hif8>) outs(%5 : !pto.tile_buf<vec, 16x16xf32>)
